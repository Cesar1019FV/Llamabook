# Llamabook backend configuration
# Copy this file to .env and adjust values

# Security
LLAMABOOK_SECRET_KEY=change-me-to-a-random-secret-of-at-least-32-characters
LLAMABOOK_ADMIN_EMAIL=admin@llamabook.local
LLAMABOOK_ADMIN_PASSWORD=admin

# Server
LLAMABOOK_HOST=127.0.0.1
LLAMABOOK_PORT=8000
LLAMABOOK_RELOAD=true
VITE_API_URL=http://127.0.0.1:8000/api/v1

# CORS (development defaults)
LLAMABOOK_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Storage
LLAMABOOK_DATA_DIR=backend/data
LLAMABOOK_MAX_UPLOAD_SIZE=52428800

# Ollama (local or cloud)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7